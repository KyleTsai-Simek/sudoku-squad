{
  "name": "@sudoku-squad/ingest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "One-off scripts for ingesting puzzles from the Kaggle 9M dataset. NOT shipped to clients.",
  "exports": {
    "./solver": "./src/solver.ts",
    "./code": "./src/code.ts"
  },
  "scripts": {
    "ingest": "tsx -r dotenv/config src/index.ts dotenv_config_path=../../.env.local",
    "ingest:qqwing": "tsx -r dotenv/config src/ingest-qqwing.ts dotenv_config_path=../../.env.local",
    "ingest:qqwing-graded": "tsx -r dotenv/config src/ingest-qqwing-graded.ts dotenv_config_path=../../.env.local",
    "check": "tsx -r dotenv/config src/check-connectivity.ts dotenv_config_path=../../.env.local",
    "audit:difficulty": "tsx -r dotenv/config src/audit-difficulty.ts dotenv_config_path=../../.env.local",
    "check:puzzle": "tsx -r dotenv/config src/check-puzzle.ts dotenv_config_path=../../.env.local",
    "verify:sync": "tsx -r dotenv/config src/verify-sync.ts dotenv_config_path=../../.env.local",
    "probe:submit-move": "tsx -r dotenv/config src/probe-submit-move.ts dotenv_config_path=../../.env.local",
    "preflight:3m": "tsx src/preflight-3m.ts",
    "verify:samples": "tsx src/verify-samples.ts",
    "ingest:dry-fixture": "tsx src/index.ts --dry-run --csv fixtures/synthetic.csv",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo 'TODO: eslint'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "qqwing": "^1.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
