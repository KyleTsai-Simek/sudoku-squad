{
  "name": "sudoku-squad",
  "version": "0.0.0",
  "private": true,
  "description": "Multiplayer sudoku — collaborative and battle modes",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @sudoku-squad/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,sql}\"",
    "build:wordlists": "pnpm dlx tsx scripts/build-word-lists.ts"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
